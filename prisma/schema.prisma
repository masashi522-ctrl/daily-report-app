generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Staff {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(STAFF)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dailyRecords DailyRecord[]
}

model Resident {
  id               String   @id @default(cuid())
  name             String
  furigana         String?
  foodType         FoodType @default(REGULAR)
  foodRestrictions String?
  specialCondition String?
  isActive         Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  dailyRecords DailyRecord[]
}

model DailyRecord {
  id         String   @id @default(cuid())
  date       DateTime @db.Date
  residentId String
  staffId    String?

  bpSystolic    Int?
  bpDiastolic   Int?
  pulse         Int?
  tempMorning   Float?
  tempAfternoon Float?

  bathing     BathingStatus @default(NOT_APPLICABLE)
  mealAmount  Int?
  fluidIntake Int?

  medicationMorning     Boolean @default(false)
  medicationBeforeLunch Boolean @default(false)
  medicationAfterLunch  Boolean @default(false)
  medicationEvening     Boolean @default(false)
  medicationNote        String?

  functionalTrainingStart String?
  functionalTrainingEnd   String?
  oralCare                Boolean @default(false)

  spo2Before Float?
  spo2After  Float?
  weight     Float?
  eyeDrops   String?
  insulin    String?

  specialNotes String?

  bathingSkipReason String?
  bathingSkipDetail String?
  bathingNote       String?

  trainingDone       Boolean @default(false)
  trainingSkipReason String?
  trainingSkipDetail String?
  trainingNote       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resident Resident @relation(fields: [residentId], references: [id])
  staff    Staff?   @relation(fields: [staffId], references: [id])

  @@unique([date, residentId])
}

enum Role {
  ADMIN
  STAFF
}

enum FoodType {
  REGULAR
  LOW_SALT
  SOFT
  MINCED
  BLENDED
  PORRIDGE
  MANNAN
  BREAD
  BLENDED_PORRIDGE
}

enum BathingStatus {
  DONE
  NOT_DONE
  NOT_APPLICABLE
}
